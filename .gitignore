# Python
__pycache__/
*.pyc
*.egg-info/

# Secrets
.env
.env.*

# Organization-specific data (created at runtime, never committed)
data/org_config.json
data/google-workspace-creds/
data/config/
data/conversations.db
data/tmp/
data/browser-profile/
data/media_cache/
data/last_*
data/m365_auth_state.json
data/m365_auth_output/

# Logs
logs/
data/logs/

# IDE / Claude (ignore sessions etc, but keep skills and settings in git)
.claude/*
!.claude/skills/
!.claude/agents/
!.claude/rules/
!.claude/settings.json
.playwright-mcp/

# Deploy artifacts (runtime state, not source)
deploy/triggers/*
!deploy/triggers/.gitkeep
deploy/deploy_watcher.log
deploy/deploy_result.json
deploy/staging-triggers/deploy_result.json
deploy/staging-triggers/approval_request.json
deploy/last_healthy_commit

# Telegram session (MTProto auth keys — NEVER commit)
data/tg_session/

# Server-specific overrides (generated by setup wizard)
docker-compose.override.yml

# Backup artifacts (NEVER commit — contains master encryption key)
.backup-password
deploy/backups/
*.7z

# Test/cache
.pytest_cache/
data/external_chats.json
deploy/token_refresh.log
data/scheduled_tasks.json
data/wa_last_poll.txt
deploy/last_failed_startup.log

data/conversations.db-shm
data/conversations.db-wal
data/pm.db
data/pm.db-shm
data/pm.db-wal
data/harnesses.json
data/chat_harnesses.json
deploy/staging_watcher.log
deploy/staging-triggers/staging_last_failed_startup.log
data/model_overrides.json
.gdrive-service-account.json
.backup-password
deploy/backup.log

# Credential directory (OAuth profiles, workspace creds, session files)
data/credentials/

# Harness project dirs (sandbox working directories)
data/harness-projects/

# Staging artifacts
data/staging-snapshot.db

# Playwright/Camoufox browser profiles
data/playwright-profiles/
data/camofox-profiles/
