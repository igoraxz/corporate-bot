# Staging environment overrides.
# Loaded AFTER .env via env_file chain — overrides only the keys listed here.
# Contains NO secrets — all API keys/tokens inherited from .env.
#
# Usage: docker compose -f docker-compose.yml -f docker-compose.staging.yml up -d

BOT_ENV=staging

# Disable Telegram (prevent MTProto session collision with prod)
TG_API_ID=0
TG_API_HASH=disabled
TG_CHAT_ID=0
TG_ALLOWED_USERS=
TG_BOT_USER_ID=0
TG_ADMIN_CHAT_IDS=

# Disable WhatsApp (no bridge in staging)
WA_BRIDGE_URL=http://localhost:9999
WA_FAMILY_GROUP_JID=
WA_ALLOWED_PHONES=
WA_BOT_PHONE=

# Disable phone calls
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=

# Disable desktop relay
DESKTOP_ENABLED=0

# Staging reports port (avoids collision with prod 8210)
REPORTS_PORT=8310

# Use cheaper model defaults for staging tests
MODEL_PRIMARY=claude-sonnet-4-6
MAX_BUDGET_DEFAULT=1
MAX_BUDGET_HEAVY=3

# Use non-rate-limited OAuth profile for staging tests
OAUTH_DEFAULT_LABEL=personal
