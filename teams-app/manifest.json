{
  "$schema": "https://developer.microsoft.com/json-schemas/teams/v1.19/MicrosoftTeams.schema.json",
  "manifestVersion": "1.19",
  "id": "${TEAMS_APP_ID}",
  "version": "1.0.0",
  "packageName": "com.example.corporatebot",
  "name": {
    "short": "Corporate Bot",
    "full": "Corporate Bot — Corporate AI Assistant"
  },
  "description": {
    "short": "AI assistant with code execution, knowledge search, and personal productivity",
    "full": "Corporate Bot is an AI-powered corporate assistant that searches knowledge bases, executes code in sandboxed environments, manages your calendar and email, browses the web, and runs scheduled tasks — all within Microsoft Teams. Powered by Claude (Anthropic)."
  },
  "developer": {
    "name": "Your Company",
    "websiteUrl": "https://your-company.example.com",
    "privacyUrl": "https://your-company.example.com/privacy",
    "termsOfUseUrl": "https://your-company.example.com/terms"
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "accentColor": "#4A90D9",
  "bots": [
    {
      "botId": "${TEAMS_APP_ID}",
      "scopes": ["personal", "team", "groupChat"],
      "supportsFiles": true,
      "isNotificationOnly": false,
      "commandLists": [
        {
          "scopes": ["personal"],
          "commands": [
            {"title": "help", "description": "Show available commands and capabilities"},
            {"title": "domains", "description": "List available knowledge domains"},
            {"title": "status", "description": "Check bot status and your session info"},
            {"title": "search", "description": "Search knowledge bases"},
            {"title": "calendar", "description": "View your upcoming events"},
            {"title": "reset", "description": "Reset your session (admin only)"}
          ]
        },
        {
          "scopes": ["team", "groupChat"],
          "commands": [
            {"title": "help", "description": "Show available commands"},
            {"title": "search", "description": "Search this channel's knowledge domains"},
            {"title": "status", "description": "Check bot status"}
          ]
        }
      ]
    }
  ],
  "permissions": ["identity", "messageTeamMembers"],
  "validDomains": ["${BOT_DOMAIN}"],
  "webApplicationInfo": {
    "id": "${TEAMS_APP_ID}",
    "resource": "api://botid-${TEAMS_APP_ID}"
  }
}
