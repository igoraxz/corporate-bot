# ============================================================
# Corporate Bot — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains secrets.
#
# DEPLOYMENT MODES:
#   Teams-only:     Set TEAMS_* + ROOT_ADMIN=teams:aad-id, leave TG_* empty
#   Telegram-only:  Set TG_* + ROOT_ADMIN=telegram:user_id, leave TEAMS_* empty
#   Dual-platform:  Set both TEAMS_* and TG_*
#
# Required vars are marked [REQUIRED]. Everything else has defaults.

# ═══════════════════════════════════════════════════════════════
# AUTHENTICATION
# ═══════════════════════════════════════════════════════════════

# Claude Code OAuth token (subscription plan — recommended)
CLAUDE_CODE_OAUTH_TOKEN=                # [REQUIRED] or use ANTHROPIC_API_KEY

# OR: Anthropic API key (pay-per-token)
# ANTHROPIC_API_KEY=

# ═══════════════════════════════════════════════════════════════
# TELEGRAM (optional — leave empty for Teams-only deployment)
# ═══════════════════════════════════════════════════════════════
# TG_MODE selects the Telegram backend:
#   "bot"     — Official Bot API via python-telegram-bot (corporate, default)
#   "userbot" — Pyrogram MTProto userbot (personal/family)

TG_MODE=bot                             # "bot" for Bot API (corporate), "userbot" for Pyrogram

# --- Bot API mode (TG_MODE=bot) ---
# Create a bot via @BotFather, get the token, set webhook URL.
TG_BOT_TOKEN=                           # [REQUIRED for bot mode] From @BotFather
TG_WEBHOOK_URL=                         # [REQUIRED for bot mode] Public HTTPS URL (e.g. https://bot.company.com)
TG_WEBHOOK_SECRET=                      # [REQUIRED] Random string for webhook verification (openssl rand -hex 32)

# --- Userbot mode (TG_MODE=userbot) ---
# Get credentials from https://my.telegram.org/apps
TG_API_ID=                              # [REQUIRED for userbot mode] API ID from my.telegram.org
TG_API_HASH=                            # [REQUIRED for userbot mode] API hash from my.telegram.org

TG_CHAT_ID=                             # [REQUIRED] Team group chat ID (negative number)

# Authorized users — format: "user_id:Name,user_id:Name"
TG_ALLOWED_USERS=                       # [REQUIRED] e.g. "123456789:John,987654321:Jane"

# Primary admin identity for system tasks and scheduled task delivery.
# Format: "source:user_id" (e.g. "telegram:123456789" or "teams:aad-object-id")
ROOT_ADMIN=                             # [REQUIRED] e.g. "teams:abc-123-def" or "telegram:123456789"

# Admin users with full bot control (self-upgrade, deploy, config)
# Format: "telegram:user_id" or "teams:aad_id" (comma-separated)
ADMIN_USERS=                            # [REQUIRED] e.g. "teams:abc-123-def"

# Admin-only chat IDs (DMs and promoted groups with full access)
# TG_ADMIN_CHAT_IDS=                    # e.g. "123456789,-100XXXXXXXXXX"

# Bot's own Telegram user ID (for filtering own messages)
# TG_BOT_USER_ID=
# TG_MCP_BOT_USER_ID=                  # Secondary MCP bot ID (optional)

# Telegram session directory and name
# TG_SESSION_DIR=/app/data/tg_session
# TG_SESSION_NAME=corporate_bot

# ═══════════════════════════════════════════════════════════════
# WHATSAPP (REMOVED in v2.2.0 — WA bridge no longer supported)
# ═══════════════════════════════════════════════════════════════
# The WhatsApp bridge (whatsmeow-based Go service) was removed in v2.2.0.
# These variables are no longer used and can be safely deleted.
# WA_BOT_PHONE=
# WA_PRIMARY_GROUP_JID=
# WA_ALLOWED_PHONES=
# WA_DB_PATH=

# ═══════════════════════════════════════════════════════════════
# GOOGLE WORKSPACE (optional — enables Gmail + Calendar for all users)
# Setup: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Desktop)
# Enable: Gmail API + Google Calendar API
# After setting these, users run /google-auth in their DM to connect their account.
# ═══════════════════════════════════════════════════════════════

# GOOGLE_OAUTH_CLIENT_ID=               # OAuth 2.0 Client ID (*.apps.googleusercontent.com)
# GOOGLE_OAUTH_CLIENT_SECRET=           # OAuth 2.0 Client Secret

# Multi-account: comma-separated email list for Google API routing
# GOOGLE_ACCOUNTS=user@gmail.com,user@example.com

# ═══════════════════════════════════════════════════════════════
# MICROSOFT 365 (optional — enables Outlook mail + calendar for all users)
# Setup: Azure AD → App registrations → new app → delegated permissions (Mail.Read, Calendars.ReadWrite)
# After setting these, users run /m365-auth in their DM to connect their account.
# ═══════════════════════════════════════════════════════════════

# MS365_MCP_CLIENT_ID=                  # Azure AD application (client) ID
# MS365_MCP_TENANT_ID=                  # Azure AD tenant ID
# MS365_MCP_CLIENT_SECRET=              # Azure AD client secret
# MS365_EMAIL=user@example.com          # Primary M365 email address
# MS365_ACCOUNT_EMAIL=user@example.com  # M365 account email for allowed_emails enforcement (Layer 1b3)

# ═══════════════════════════════════════════════════════════════
# MS TEAMS BOT (optional — omit to disable)
# ═══════════════════════════════════════════════════════════════
# Requires Azure AD app registration + Azure Bot Service resource (both free).
# Webhook endpoint: POST /api/teams-messages (needs public HTTPS via Cloudflare Tunnel etc.)

TEAMS_ENABLED=true                       # [REQUIRED for corporate] Enable Teams bot
TEAMS_APP_ID=                            # [REQUIRED] Azure AD application (client) ID
TEAMS_APP_SECRET=                        # [REQUIRED] Azure AD client secret (keep in .env only!)
TEAMS_TENANT_ID=                         # [REQUIRED] Azure AD tenant ID (single-tenant bot)
# TEAMS_ALLOWED_TENANTS=                 # Comma-separated tenant IDs (empty = own tenant only)
TEAMS_DEFAULT_HARNESS=employee           # Default harness for new Teams chats

# ═══════════════════════════════════════════════════════════════
# CORPORATE AUTH (per-user SSO + token vault)
# ═══════════════════════════════════════════════════════════════

# Token encryption key for per-user OAuth vault (Fernet symmetric)
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=                    # [REQUIRED for SSO] Fernet key

# MS365 Graph API (defaults to TEAMS_APP values if omitted — shared app registration)
# MS365_CLIENT_ID=                       # Override if separate app for Graph API
# MS365_CLIENT_SECRET=
# MS365_TENANT_ID=
# MS365_SCOPES=Mail.Read,Calendars.ReadWrite,User.Read

# Bot Admin — Azure AD Object IDs with full bot access (comma-separated)
BOT_ADMIN_AAD_IDS=                       # [REQUIRED] e.g. "abc-123-def,xyz-789-uvw"

# ═══════════════════════════════════════════════════════════════
# KNOWLEDGE DOMAINS (GitHub + Graph API sync)
# ═══════════════════════════════════════════════════════════════

# GitHub — domain sync + user auth
GITHUB_TOKEN=                            # [REQUIRED for GitHub domains] PAT with repo read access
GITHUB_WEBHOOK_SECRET=                   # Generate: openssl rand -hex 32
# GitHub OAuth App (optional — enables /github-auth device flow for users)
# Setup: GitHub → Settings → Developer settings → OAuth Apps → New → enable Device Flow
# GITHUB_OAUTH_CLIENT_ID=                # OAuth App client ID (no secret needed for device flow)

# Graph API document sources (SharePoint/Teams/OneDrive) use the MS365 credentials above.
# Required Azure AD permissions: Files.Read.All, Sites.Read.All
# No additional env vars needed — uses TEAMS_APP_ID/SECRET or MS365_CLIENT_ID/SECRET.

# ═══════════════════════════════════════════════════════════════
# AI SERVICES
# ═══════════════════════════════════════════════════════════════

# Gemini API — REQUIRED: powers RAG semantic search (embeddings), media descriptions,
# document parsing, knowledge domain maps, image generation.
# Get key at: https://aistudio.google.com/apikey (free tier available)
GEMINI_API_KEY=                         # Google AI API key — REQUIRED for RAG
# GEMINI_MODEL_DESCRIBE=gemini-2.5-flash-lite  # Model for doc parsing + knowledge maps (default: gemini-2.5-flash-lite)

# Vapi — outbound phone calls via AI voice agent
# VAPI_API_KEY=                         # From vapi.ai dashboard
# VAPI_PHONE_NUMBER_ID=                 # Vapi phone number ID
# VAPI_VOICE_ID=                        # Voice agent voice selection
# WEBHOOK_BASE_URL=                     # Public URL, e.g. https://bot.example.com

# ═══════════════════════════════════════════════════════════════
# BROWSER AUTOMATION
# ═══════════════════════════════════════════════════════════════

# Camoufox anti-detect browser (shared secret between containers)
# CAMOFOX_API_KEY=                      # Generate: openssl rand -base64 32
# CAMOFOX_BROWSER_URL=http://camofox-browser:9377
# CAMOFOX_SESSION_TIMEOUT=0             # 0 = no idle timeout
# CAMOFOX_AUTO_SAVE=true                # Auto-save profiles on tab close

# Playwright MCP (shared SSE server)
# PLAYWRIGHT_MCP_PORT=3001

# Browser pool (manages tabs across chats with LRU eviction)
# BROWSER_POOL_IMMUNE_SLOTS=6           # Admin/team tabs (immune from eviction)
# BROWSER_POOL_LRU_SLOTS=6              # Coding/discovered tabs (LRU-evictable)

# ═══════════════════════════════════════════════════════════════
# DESKTOP RELAY (optional — Mac Claude Code sessions via SSH)
# ═══════════════════════════════════════════════════════════════

# DESKTOP_ENABLED=true                  # Enable desktop relay feature
# DESKTOP_HOST=your-mac-hostname        # Mac hostname or Tailscale IP
# DESKTOP_USER=username                 # Mac username for SSH
# DESKTOP_SSH_KEY=~/.ssh/id_ed25519     # SSH key for Mac connection

# Tailscale dynamic IP resolution (alternative to static DESKTOP_HOST)
# TAILSCALE_OAUTH_CLIENT_ID=            # Tailscale OAuth client ID (devices:read scope)
# TAILSCALE_OAUTH_CLIENT_SECRET=        # Tailscale OAuth client secret
# TAILSCALE_TAILNET=                    # Tailnet name
# TAILSCALE_HOSTNAME=                   # Mac's Tailscale hostname
# MAC_IP_TTL_S=60                       # IP cache TTL (seconds)

# ═══════════════════════════════════════════════════════════════
# CLAUDE SDK CONFIGURATION
# ═══════════════════════════════════════════════════════════════

# Model selection
# MODEL_PRIMARY=claude-sonnet-4-6       # Default model (sonnet = 5x cheaper)
# ORCHESTRATOR_MODEL=claude-sonnet-4-6  # Model for pipeline orchestrator AI review (default: claude-sonnet-4-6)

# Session budget caps (cumulative USD per session)
# MAX_BUDGET_DEFAULT=0                  # Sonnet session cap (0 = no cap)
# MAX_BUDGET_HEAVY=0                    # Opus session cap (0 = no cap)
# MAX_EXTEND_DELTA_USD=100              # Max single budget extension
# MAX_TOTAL_BUDGET_CAP=500              # Absolute session budget ceiling

# Output token limits per query
# QUERY_OUTPUT_CAP_DEFAULT=0            # Sonnet output cap (0 = no cap)
# QUERY_OUTPUT_CAP_HEAVY=0              # Opus output cap (0 = no cap)

# SDK connection resilience
# SDK_CONNECT_RETRIES=2                 # Retry count on connect failure
# SDK_CONNECT_BACKOFF_BASE=3            # Exponential backoff base (seconds)
# SDK_INIT_TIMEOUT=180                  # SDK initialization timeout (seconds)

# Rate limit monitoring
# RATE_LIMIT_WARN_PCT=0.75             # Warning threshold (75%)
# RATE_LIMIT_ALERT_PCT=0.90            # Alert threshold (90%)
# RATE_LIMIT_ALERT_COOLDOWN_S=1800     # Cooldown between alerts (30 min)
# QUERY_COST_WARN=2.0                  # Per-query cost anomaly threshold ($)

# ═══════════════════════════════════════════════════════════════
# MEDIA & STORAGE
# ═══════════════════════════════════════════════════════════════

# Media descriptions (Gemini Flash auto-describes all incoming media)
# MEDIA_DESCRIPTION_ENABLED=true
# MEDIA_DESCRIPTION_BACKFILL_LIMIT=20   # Items to backfill on startup
# MEDIA_DESCRIBE_MAX_SIZE_MB=100        # Max file size for description
# MEDIA_DESCRIBE_INLINE_SIZE_MB=20      # Threshold for inline vs File API
# MEDIA_DESCRIBE_TIMEOUT_S=120          # Per-file description timeout
# MEDIA_DESCRIBE_MAX_CONCURRENT=3       # Max parallel descriptions

# Voice transcription
# VOICE_TRANSCRIBE_TIMEOUT_S=60
# VOICE_TRANSCRIBE_MAX_CHARS=20000

# Media cache retention
# MEDIA_RETENTION_DAYS=36135            # Default: ~99 years (permanent)

# SQLite database
# DB_BUSY_TIMEOUT=5000                  # Lock timeout (ms)
# DATA_DIR=/app/data                    # Data directory path

# RAG search
# RAG_SEARCH_BATCH_SIZE=50000           # Chunks per search batch (default: 50000)

# ═══════════════════════════════════════════════════════════════
# TASK PROCESSING
# ═══════════════════════════════════════════════════════════════

# Parallel task limits
# MAX_PARALLEL_TASKS=1                  # Tasks per chat (sequential)
# MAX_TOTAL_TASKS=10                    # Global concurrent task cap

# Zombie detection
# TASK_STALE_TIMEOUT_S=900             # Kill stale tasks after 15 min

# Burst-message coalescing
# PQ_DISPATCH_DEBOUNCE_MS=150          # Debounce window for merging rapid messages

# Streaming UI
# PLACEHOLDER_DELAY=1.5                # Seconds before "Thinking..." appears

# Tool timeout
# TG_TOOL_TIMEOUT=600                  # Telegram tool timeout (seconds)

# ═══════════════════════════════════════════════════════════════
# LOCALIZATION (optional — for non-English cancel/continue words)
# ═══════════════════════════════════════════════════════════════

# LOCALE_CANCEL_WORDS=                  # e.g. "отмена|стоп" for Russian
# LOCALE_CANCEL_PREFIX=                 # e.g. "отмени эту"
# LOCALE_CONTINUE_WORDS=               # e.g. "продолжай"
# LOCALE_DIAGNOSE_WORDS=               # Diagnostic keywords
# LOCALE_DROP_WORDS=                    # e.g. "положи трубку" (hang up)

# ═══════════════════════════════════════════════════════════════
# DOCKER & DEPLOYMENT
# ═══════════════════════════════════════════════════════════════

COMPOSE_PROJECT_NAME=corporate-bot      # Docker container name prefix
BOT_PORT=8000                           # Host port to expose
TZ=Europe/London                        # Timezone for container and bot
# HOST=0.0.0.0                          # Server bind address
# BOT_ENV=production                    # production | staging
# STAGING_URL=http://corporate-bot-staging:8000

# Kiwi Flights MCP (remote, no key needed)
# KIWI_MCP_URL=https://mcp.kiwi.com

# OAuth profile management
# OAUTH_DEFAULT_LABEL=default           # Default OAuth profile label
